NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/universal-archive
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
UPLOAD_MAX_SIZE=10485760
